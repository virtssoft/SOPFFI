rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@sopffi.org" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Volunteers
    match /volunteers/{volunteerId} {
      allow create: if true; // Anyone can apply
      allow read, write: if isAdmin();
    }

    // Partners
    match /partners/{partnerId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }

    // Posts
    match /posts/{postId} {
      allow read: if true; // Public blog
      allow write: if isAdmin();
    }

    // Province Activities
    match /province_activities/{activityId} {
      allow read: if true; // Public list
      allow write: if isAdmin();
    }

    // Admins helper
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only manageable via console or specialized function
    }
  }
}
